---
interface Props {
  titleEs: string;
  titleEn: string;
  descriptionEs: string;
  descriptionEn: string;
  techStack: string[];
}

const { titleEs, titleEn, descriptionEs, descriptionEn, techStack } = Astro.props;
---
<div class="bg-surface rounded-card border border-border p-6
            hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <h3 class="font-display font-bold text-lg mb-2">
    <span data-lang="es">{titleEs}</span>
    <span data-lang="en">{titleEn}</span>
  </h3>
  <p class="text-muted text-sm leading-relaxed mb-4">
    <span data-lang="es">{descriptionEs}</span>
    <span data-lang="en">{descriptionEn}</span>
  </p>
  <div class="flex flex-wrap gap-1.5">
    {techStack.map((tech) => (
      <span class="text-xs bg-surface-alt text-muted px-2 py-1 rounded-full">{tech}</span>
    ))}
  </div>
</div>
