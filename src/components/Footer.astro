---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="bg-slate text-white/80 mt-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Brand -->
      <div>
        <a href={lang === 'es' ? '/' : '/en/'} class="font-display font-extrabold text-xl text-white">
          Jorge<span class="text-blue">.</span>
        </a>
        <p class="mt-2 text-sm text-white/50 max-w-xs">
          <span data-lang="es">NetSuite & Integration Specialist en Melbourne, Australia.</span>
          <span data-lang="en">NetSuite & Integration Specialist in Melbourne, Australia.</span>
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-12 text-sm">
        <div>
          <h4 class="font-display font-bold text-white mb-3">
            <span data-lang="es">Navegación</span>
            <span data-lang="en">Navigation</span>
          </h4>
          <ul class="flex flex-col gap-2">
            <li><a href={`${lang === 'es' ? '/' : '/en/'}#about`} class="hover:text-white transition-colors">
              <span data-lang="es">Sobre mí</span>
              <span data-lang="en">About</span>
            </a></li>
            <li><a href={`${lang === 'es' ? '/' : '/en/'}#projects`} class="hover:text-white transition-colors">
              <span data-lang="es">Proyectos</span>
              <span data-lang="en">Projects</span>
            </a></li>
            <li><a href={lang === 'es' ? '/articles/' : '/en/articles/'} class="hover:text-white transition-colors">
              <span data-lang="es">Artículos</span>
              <span data-lang="en">Articles</span>
            </a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-display font-bold text-white mb-3">
            <span data-lang="es">Contacto</span>
            <span data-lang="en">Contact</span>
          </h4>
          <ul class="flex flex-col gap-2">
            <li>
              <a href="https://www.linkedin.com/in/jorgeiriarte/"
                 target="_blank"
                 rel="noopener noreferrer"
                 class="hover:text-white transition-colors">
                LinkedIn
              </a>
            </li>
            <li>
              <a href="mailto:jorge.iriarte@fusion5.com.au"
                 class="hover:text-white transition-colors">
                Email
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/10 mt-8 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-white/40">
        &copy; {year} Jorge Iriarte.
        <span data-lang="es">Todos los derechos reservados.</span>
        <span data-lang="en">All rights reserved.</span>
      </p>

      <!-- Back to top -->
      <button
        id="back-to-top"
        class="text-xs text-white/40 hover:text-white transition-colors flex items-center gap-1 cursor-pointer"
        aria-label="Back to top">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
        <span data-lang="es">Volver arriba</span>
        <span data-lang="en">Back to top</span>
      </button>
    </div>
  </div>
</footer>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
