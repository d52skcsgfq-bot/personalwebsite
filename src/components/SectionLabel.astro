---
interface Props {
  iconPath: string;
  labelEs: string;
  labelEn: string;
}

const { iconPath, labelEs, labelEn } = Astro.props;
---
<div class="flex items-center gap-2 mb-4">
  <div class="w-5 h-5 text-blue">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
    </svg>
  </div>
  <span class="text-xs font-semibold uppercase tracking-widest text-blue" data-lang="es">{labelEs}</span>
  <span class="text-xs font-semibold uppercase tracking-widest text-blue" data-lang="en">{labelEn}</span>
</div>
