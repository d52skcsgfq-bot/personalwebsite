---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  lang: 'es' | 'en';
  image?: string;
}

const { title, description, date, tags, slug, lang, image } = Astro.props;
const url = lang === 'es' ? `/articles/${slug}/` : `/en/articles/${slug}/`;
const formattedDate = date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<a href={url} class="block group">
  <article class="bg-surface rounded-card border border-border overflow-hidden
                  hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
    <!-- Cover image (optional) -->
    {image && (
      <img
        src={image}
        alt={title}
        width="1200"
        height="630"
        loading="lazy"
        decoding="async"
        class="w-full aspect-[1200/630] object-cover bg-surface-alt"
      />
    )}

    <div class="p-6">
      <!-- Date -->
      <time class="text-xs text-muted font-medium" datetime={date.toISOString()}>
        {formattedDate}
      </time>

      <!-- Title -->
      <h3 class="font-display font-bold text-lg mt-2 mb-2
                 group-hover:text-blue transition-colors">
        {title}
      </h3>

      <!-- Description -->
      <p class="text-muted text-sm leading-relaxed mb-4">
        {description}
      </p>

      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="text-xs bg-surface-alt text-muted px-2 py-0.5 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      <!-- Read more -->
      <p class="text-blue text-sm font-medium mt-4 flex items-center gap-1
                group-hover:gap-2 transition-all">
        {lang === 'es' ? 'Leer más' : 'Read more'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </p>
    </div>
  </article>
</a>
