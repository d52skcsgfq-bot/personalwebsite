---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import SectionLabel from '../../../components/SectionLabel.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) =>
  data.lang === 'en' && !data.draft
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout
  title="Articles on NetSuite & Integrations — Jorge Iriarte"
  description="Technical articles about NetSuite integrations, Celigo, Shopify, APIs and enterprise automation."
  lang="en"
  alternateUrl="/articles/"
>
  <section class="pt-28 pb-16 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <SectionLabel
        iconPath="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
        labelEs="Artículos"
        labelEn="Articles"
      />

      <h1 class="font-display font-extrabold text-3xl mb-4
                  sm:text-4xl">
        Articles
      </h1>
      <p class="text-muted text-lg mb-10 max-w-2xl">
        Technical reflections on enterprise integrations, NetSuite, automation, and the tools I use every day.
      </p>

      {articles.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              date={article.data.date}
              tags={article.data.tags}
              slug={article.data.urlSlug || article.id}
              image={article.data.image}
              lang="en"
            />
          ))}
        </div>
      ) : (
        <p class="text-muted">No articles published yet.</p>
      )}
    </div>
  </section>
</BaseLayout>
